{
  "name": "inv-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "test": "vitest run --pool=vmThreads --no-file-parallelism --maxWorkers=1",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --pool=vmThreads --no-file-parallelism --maxWorkers=1"
  },
  "dependencies": {
    "antd": "^5.27.4",
    "file-saver": "^2.0.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.8.2",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^29.1.1",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "js-yaml": "4.2.0"
  },
  "engines": {
    "node": ">=22.12.0 <23"
  }
}
