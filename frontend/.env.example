# IMS Frontend Runtime — SQLite-first local pilot
# sqlite = auth lokal backend SQLite untuk pilot LAN/offline.
# firebase = fallback legacy sampai migrasi semua modul selesai dan aman.
VITE_AUTH_MODE=sqlite

# Kosongkan agar frontend otomatis memakai host saat ini + port 3001.
# Isi manual hanya jika backend SQLite memakai host/port berbeda.
# VITE_SQLITE_API_BASE_URL=http://localhost:3001

# C1: Supplier master-only boleh memakai SQLite.
# Catatan: katalog raw material/purchase history masih legacy read-only; stock/purchase/finance tidak ikut dimutasi.
VITE_SUPPLIERS_REPOSITORY_MODE=sqlite

# D1: Pricing Rules disimpan di SQLite local.
# Apply harga massal tetap guarded sampai target Product/Raw Material sepenuhnya SQLite.
VITE_PRICING_RULES_REPOSITORY_MODE=sqlite
