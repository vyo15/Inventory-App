# IMS Frontend Runtime — database lokal
# sqlite = auth dan database lokal untuk mode offline internal.
# Nilai mode lama akan dinormalisasi ke database lokal; jangan aktifkan runtime arsip.
VITE_AUTH_MODE=sqlite

# Kosongkan agar frontend otomatis memakai host saat ini + port 3001.
# Isi manual hanya jika layanan database lokal memakai host/port berbeda.
# VITE_SQLITE_API_BASE_URL=http://localhost:3001

# Supplier memakai database lokal.
# Catatan: katalog raw material/purchase history lama masih read-only; stock/purchase/finance tidak ikut dimutasi.
VITE_SUPPLIERS_REPOSITORY_MODE=sqlite

# Pricing Rules disimpan di database lokal.
# Apply harga massal tetap guarded dan wajib lewat service resmi.
VITE_PRICING_RULES_REPOSITORY_MODE=sqlite
# Master data Product/Raw/Semi dan snapshot stok memakai database lokal.
# Production flow yang memutasi material usage/payroll/HPP tetap guarded.
VITE_PRODUCTS_REPOSITORY_MODE=sqlite
VITE_RAW_MATERIALS_REPOSITORY_MODE=sqlite
VITE_STOCK_READ_MODELS_REPOSITORY_MODE=sqlite
VITE_SEMI_FINISHED_REPOSITORY_MODE=sqlite

# Stock adjustment/transaksi/finance/report memakai database lokal untuk transaksi baru.
# Production/Payroll/HPP tetap guarded sampai workflow material usage + payroll final audited khusus.
VITE_STOCK_ADJUSTMENTS_REPOSITORY_MODE=sqlite
VITE_TRANSACTIONS_REPOSITORY_MODE=sqlite
VITE_FINANCE_REPOSITORY_MODE=sqlite
VITE_PRODUCTION_REPOSITORY_MODE=sqlite
VITE_REPORTS_REPOSITORY_MODE=sqlite
