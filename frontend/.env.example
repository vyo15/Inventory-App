# IMS Frontend Runtime — SQLite lokal sebagai satu-satunya source of truth.
# Runtime Firebase/Firestore/IndexedDB dan pemilihan repository per modul sudah tidak didukung.
VITE_AUTH_MODE=sqlite

# Kosongkan agar frontend otomatis memakai host saat ini + port 3001.
# Isi manual hanya jika layanan database lokal memakai host/port berbeda.
# VITE_SQLITE_API_BASE_URL=http://localhost:3001

# Variabel VITE_*_REPOSITORY_MODE versi lama sengaja tidak digunakan lagi.
# Jika masih ada di .env.local lama, runtime tetap memakai SQLite lokal.
