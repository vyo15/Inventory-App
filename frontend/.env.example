# IMS Frontend Runtime
# firebase = auth lama tetap aktif dan kompatibel
# sqlite = auth lokal backend SQLite opt-in untuk pilot LAN/offline
VITE_AUTH_MODE=firebase

# Kosongkan agar frontend otomatis memakai host saat ini + port 3001.
# Isi manual hanya jika backend SQLite memakai host/port berbeda.
# VITE_SQLITE_API_BASE_URL=http://localhost:3001

# Guarded: Supplier default tetap Firebase. Set sqlite hanya untuk pilot master data setelah audit manual.
VITE_SUPPLIERS_REPOSITORY_MODE=firebase
