{
  "name": "ims-sqlite-sidecar-backend",
  "version": "0.1.0",
  "private": true,
  "description": "IMS Bunga Flanel SQLite sidecar backend for full-offline LAN POC.",
  "main": "src/server.js",
  "scripts": {
    "dev": "npm run check:runtime && nodemon src/server.js",
    "start": "npm run check:runtime && node src/server.js",
    "check:syntax": "node scripts/check-all-js.cjs",
    "lint": "eslint \"src/**/*.{js,cjs,mjs}\" \"test/**/*.{js,cjs,mjs}\" \"scripts/**/*.{js,cjs,mjs}\"",
    "check": "npm run check:runtime && npm run check:syntax && npm run lint",
    "test": "npm run check:runtime && node scripts/run-tests.cjs",
    "audit:sqlite-cutover": "node scripts/audit-sqlite-cutover-readiness.cjs",
    "check:runtime": "node ../scripts/check-node-version.cjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "globals": "^16.3.0",
    "nodemon": "^3.1.4"
  },
  "overrides": {
    "tar": "7.5.16",
    "undici": "6.27.0"
  },
  "engines": {
    "node": ">=22.12.0 <23"
  }
}
