# IMS SQLite sidecar backend configuration
PORT=3001
HOST=0.0.0.0
IMS_SQLITE_DB_PATH=../data/ims-sqlite-sidecar.sqlite
IMS_SQLITE_BACKUP_DIR=../backups/sqlite

# Origin frontend tambahan, dipisahkan koma. Origin dengan hostname yang sama seperti backend
# otomatis diizinkan, termasuk akses LAN via http://IP-LAPTOP:5173 -> http://IP-LAPTOP:3001.
# Jangan gunakan wildcard "*" saat cookie credential aktif.
IMS_SQLITE_CORS_ORIGIN=

# Cookie session HttpOnly. Tetap false untuk runtime HTTP lokal/LAN.
# Ubah true hanya jika frontend dan backend benar-benar berjalan melalui HTTPS.
IMS_AUTH_COOKIE_SECURE=false
# Compatibility sementara untuk session lama sebelum migrasi cookie HttpOnly selesai.
# Ubah ke false hanya setelah seluruh perangkat login ulang dan tidak lagi memakai token localStorage.
IMS_AUTH_ALLOW_LEGACY_BEARER=true

# Opsional: kode setup administrator pertama yang stabil (minimal 8 karakter).
# Jika kosong, backend membuat kode acak baru dan menampilkannya di terminal saat startup.
IMS_AUTH_BOOTSTRAP_CODE=

# Maksimal 5 login/setup gagal per IP dalam 60 detik. Request berhasil tidak menghabiskan kuota.
IMS_AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
IMS_AUTH_LOGIN_RATE_LIMIT_MAX=5

# Restore guarded memakai keyword tetap RESTORE SQLITE dan wajib session administrator lokal.
# Jangan taruh password admin di file .env.
