# IMS SQLite sidecar backend configuration
PORT=3001
HOST=0.0.0.0
IMS_SQLITE_DB_PATH=../data/ims-sqlite-sidecar.sqlite
IMS_SQLITE_BACKUP_DIR=../backups/sqlite
IMS_SQLITE_CORS_ORIGIN=*

# Restore guarded memakai keyword tetap RESTORE SQLITE dan wajib session administrator lokal.
# Jangan taruh password/admin secret di file .env. Bootstrap admin dibuat via /api/auth/bootstrap-admin.
