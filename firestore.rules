rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    /*
      IMS NOTE [AKTIF/GUARDED] — Source-controlled Firestore Rules.
      Fungsi blok:
      - Semua akses wajib memakai Firebase Auth session.
      - Role/status aplikasi dibaca dari system_users/{request.auth.uid}.
      - Fallback default deny untuk collection yang belum dipetakan.
      Behavior: staged-final rules sesuai role aktif administrator/user; bukan schema baru.
    */
    function isSignedIn() {
      return request.auth != null;
    }

    function actorProfilePath() {
      return /databases/$(database)/documents/system_users/$(request.auth.uid);
    }

    function hasActorProfile() {
      return isSignedIn() && exists(actorProfilePath());
    }

    function actorProfile() {
      return get(actorProfilePath()).data;
    }

    function hasActiveProfile() {
      return hasActorProfile()
        && actorProfile().status == 'active'
        && actorProfile().role in ['administrator', 'user'];
    }

    function isAdministrator() {
      return hasActiveProfile() && actorProfile().role == 'administrator';
    }

    function isSelf(targetUid) {
      return isSignedIn() && request.auth.uid == targetUid;
    }

    function isAllowedProfileRole(data) {
      return data.role in ['administrator', 'user'];
    }

    function isSelfLastLoginAuditUpdate(targetUid) {
      return hasActiveProfile()
        && isSelf(targetUid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLoginAt']);
    }

    function isKnownBusinessCollection(collectionName) {
      return collectionName in [
        'categories',
        'customers',
        'expenses',
        'incomes',
        'inventory_logs',
        'pricing_logs',
        'pricing_rules',
        'products',
        'purchases',
        'raw_materials',
        'returns',
        'revenues',
        'sales',
        'semi_finished_materials',
        'stock_adjustments',
        'stock_item_read_models',
        'supplierPurchases',
        'production_boms',
        'production_employee_code_sequences',
        'production_employees',
        'production_orders',
        'production_payrolls',
        'production_plans',
        'production_profiles',
        'production_steps',
        'production_work_logs',
        'productions'
      ];
    }

    function isAdminOnlyCollection(collectionName) {
      return collectionName in [
        'maintenance_logs',
        'testing_baselines'
      ];
    }

    match /system_users/{targetUid} {
      /*
        IMS NOTE [AKTIF/GUARDED] — Profile user internal IMS.
        Fungsi blok:
        - User login hanya boleh membaca profile sendiri.
        - Administrator boleh membaca daftar dan mengelola profile user lain.
        - User boleh update lastLoginAt miliknya sendiri sebagai audit best-effort AuthContext.
        Behavior: role aktif tetap hanya administrator/user; super_admin tidak dihidupkan kembali.
      */
      allow get: if hasActiveProfile() && (isSelf(targetUid) || isAdministrator());
      allow list: if isAdministrator();

      allow create: if isAdministrator()
        && !isSelf(targetUid)
        && isAllowedProfileRole(request.resource.data)
        && request.resource.data.authUid == targetUid;

      allow update: if (
        isAdministrator()
        && !isSelf(targetUid)
        && isAllowedProfileRole(request.resource.data)
        && resource.data.authUid == targetUid
        && request.resource.data.authUid == targetUid
      ) || isSelfLastLoginAuditUpdate(targetUid);

      allow delete: if isAdministrator()
        && !isSelf(targetUid);
    }

    match /{collectionName}/{documentId} {
      /*
        IMS NOTE [GUARDED/CLEANUP CANDIDATE] — Staged-final business collection access.
        Fungsi blok:
        - Profile aktif boleh read/create/update collection bisnis utama agar flow client existing tidak putus.
        - Delete destructive dibatasi Administrator.
        Batasan:
        - Karena source saat ini belum memakai backend trusted/Cloud Functions, beberapa write turunan finance
          dari Sales/Purchases tetap harus diizinkan untuk role aktif agar flow operasional tidak permission denied.
        - Field-level validation bisnis perlu task rules lanjutan setelah matriks write per modul dikunci.
      */
      allow read, create, update: if hasActiveProfile()
        && isKnownBusinessCollection(collectionName);

      allow delete: if isAdministrator()
        && isKnownBusinessCollection(collectionName);

      allow read, write: if isAdministrator()
        && isAdminOnlyCollection(collectionName);
    }

    match /{document=**} {
      /*
        IMS NOTE [GUARDED] — Fallback deny.
        Fungsi blok: menutup collection yang belum dipetakan agar rules tidak kembali ke allow-all.
      */
      allow read, write: if false;
    }
  }
}
