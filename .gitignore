# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
# Guard accidental nested frontend created by running npm from the wrong folder.
frontend/frontend/
dist/
dist-ssr/
frontend/dist/
frontend/dist-ssr/
build/
coverage/
/.artifacts/
.cache/
.vite/

# Local env
*.local
.env
backend/.env
frontend/.env

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Root build artifacts accidentally committed; keep frontend/src/assets tracked.
/assets/

# IMS SQLite local backend runtime data
/data/*
!/data/.gitkeep
/backups/*
!/backups/.gitkeep
!/backups/sqlite/
/backups/sqlite/*
!/backups/sqlite/.gitkeep
*.sqlite
*.sqlite-wal
*.sqlite-shm
