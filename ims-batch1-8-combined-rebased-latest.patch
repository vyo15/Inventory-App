+const safeTrim = (value) => String(value ?? "").trim();
+const normalizeType = (value) => safeTrim(value).toLowerCase();
+const toNumber = (value) => {
+  const numericValue = Number(value || 0);
+  return Number.isFinite(numericValue) ? numericValue : 0;
+};
