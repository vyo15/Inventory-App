{
  "name": "ims-offline-web",
  "version": "0.1.0",
  "private": true,
  "description": "IMS Bunga Flanel offline web monorepo runner.",
  "scripts": {
    "check:runtime": "node scripts/check-node-version.cjs",
    "dev": "node scripts/dev-all.cjs",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0",
    "dev:backend": "npm --prefix backend run dev",
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "check": "node scripts/git-check.cjs --full --skip-source",
    "test:scripts": "node --test scripts/run-command.test.cjs scripts/check-frontend-bundle.test.cjs scripts/check-node-version.test.cjs scripts/dev-all.test.cjs",
    "test": "npm run test:scripts && npm --prefix backend test && npm --prefix frontend test",
    "check:backend": "npm --prefix backend run check",
    "build:frontend": "npm --prefix frontend run build",
    "clean:zip": "bash scripts/create-clean-zip.sh",
    "clean:zip:ps": "powershell -ExecutionPolicy Bypass -File scripts/create-clean-zip.ps1",
    "verify:source": "node scripts/verify-source-ready.cjs",
    "verify:zip": "node scripts/verify-source-ready.cjs --archive-only",
    "verify:before-push": "node scripts/git-check.cjs --full",
    "git:setup": "node scripts/install-git-shortcuts.cjs",
    "git:check": "node scripts/git-check.cjs",
    "git:check:full": "node scripts/git-check.cjs --full",
    "git:push": "node scripts/git-push-safe.cjs",
    "check:bundle": "node scripts/check-frontend-bundle.cjs",
    "sbom": "node scripts/generate-sbom.cjs"
  },
  "engines": {
    "node": ">=22.12.0 <23"
  }
}
